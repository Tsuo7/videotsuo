    end
end)

Tabs.Visual:AddColorpicker("ESPColor", {Title = "ESP Color", Default = Color3.fromRGB(140, 82, 255)}):OnChanged(function()
    ESPParams.Color = Options.ESPColor.Value
    for _, h in pairs(ESPCache) do
        if h then h.FillColor = ESPParams.Color end
    end
end)

-- Lógica ESP segura
RunService.Heartbeat:Connect(function()
    if ESPParams.Enabled then
        for _, v in pairs(Players:GetPlayers()) do
            if v ~= LocalPlayer and UPE.IsAlive(v) then
                if not ESPCache[v] then
                    local h = Instance.new("Highlight")
                    h.FillColor = ESPParams.Color
                    h.OutlineColor = Color3.fromRGB(255, 255, 255)
                    h.FillTransparency = 0.5
                    h.OutlineTransparency = 0.1
                    h.Parent = CoreGui
                    h.Adornee = v.Character
                    ESPCache[v] = h
                else
                    ESPCache[v].Adornee = v.Character
                end
            elseif not UPE.IsAlive(v) and ESPCache[v] then
                ESPCache[v]:Destroy()
                ESPCache[v] = nil
            end
        end
    end
end)

