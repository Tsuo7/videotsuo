-- UPE: Universal Player Engine (Reconhecimento Global)
local UPE = {}

function UPE.GetRoot(character)
    if not character then return nil end
    return character:FindFirstChild("HumanoidRootPart") 
        or character:FindFirstChild("Torso") 
        or character:FindFirstChild("UpperTorso") 
        or character.PrimaryPart
end

function UPE.GetHealth(character)
    if not character then return 0, 0 end
    local hum = character:FindFirstChildOfClass("Humanoid")
    if hum then return hum.Health, hum.MaxHealth end
    -- Suporte para jogos custom (ex: atributos no character)
    local customHealth = character:GetAttribute("Health") or 100
    return customHealth, 100 
end

function UPE.IsAlive(player)
    if not player or not player.Character then return false end
    local health = UPE.GetHealth(player.Character)
    return health > 0
end

function UPE.GetTeam(player)
    if player.Team then return player.Team end
    if player.TeamColor then return player.TeamColor end
    return player:GetAttribute("Team") or "None"
end

